generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  // Identity
  firstName String
  lastName  String

  gender      Gender
  dateOfBirth DateTime

  email       String @unique
  phoneNumber String @unique

  nationality String
  country     String
  city        String

  motherTongue String

  religion String
  caste    String?

  // Physical
  heightCm Int
  weightKg Int?

  // Education
  collegeName          String
  degree               String
  highestQualification String

  // Career
  currentCompany String
  designation    String
  annualIncome   Float?

  // Family
  brothers Int @default(0)
  sisters  Int @default(0)

  maritalStatus MaritalStatus
  haveChildren  Boolean       @default(false)

  // Lifestyle
  foodPreference FoodPreference

  smoking  HabitFrequency
  drinking HabitFrequency

  lifestyle String?

  hobbies String[]

  personalityType PersonalityType

  // Matchmaking
  manglikStatus      ManglikStatus
  horoscopeAvailable Boolean       @default(false)

  disabilityStatus String?

  // Future Plans
  wantKids            PreferenceChoice
  kidsCountPreference KidsCountPreference?

  openToRelocate PreferenceChoice

  openToPets PreferenceChoice

  wantToWorkAfterMarriage PreferenceChoice

  // Languages
  languagesKnown String[]

  // Embedding Fields
  aboutMe String

  familyValues String?

  careerGoals String?

  relationshipValues String?

  futurePlans String?

  lookingFor String

  partnerExpectations String?

  // Misc
  additionalInfo String?

  // Media
  profilePictures String[]

  isVerified Boolean @default(false)

  // Embedding
  embedding Float[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerPreference PartnerPreference?
  journey           CustomerJourney?
  matches           Match[]            @relation("ProfileMatches")
  matchedBy         Match[]            @relation("MatchedProfileMatches")
}

model PartnerPreference {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  profileId String  @unique @db.ObjectId
  profile   Profile @relation(fields: [profileId], references: [id])

  // Hard Filters

  minAge Int?
  maxAge Int?

  minHeightCm Int?
  maxHeightCm Int?

  religion String?
  caste    String?

  smoking  HabitFrequency?
  drinking HabitFrequency?

  maritalStatus MaritalStatus?

  foodPreference FoodPreference?

  city String?

  degree String?

  minIncome Float?

  // Soft Filters

  wantKids       PreferenceChoice?
  openToRelocate PreferenceChoice?
  openToPets     PreferenceChoice?

  partnerDescription String?
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  NEVER_MARRIED
  DIVORCED
  WIDOWED
}

enum HabitFrequency {
  NO
  OCCASIONALLY
  YES
}

enum PreferenceChoice {
  YES
  NO
  MAYBE
}

enum PersonalityType {
  INTROVERT
  AMBIVERT
  EXTROVERT
}

enum FoodPreference {
  VEG
  EGGETARIAN
  NON_VEG
  JAIN
}

enum ManglikStatus {
  YES
  NO
  UNKNOWN
}

enum KidsCountPreference {
  ONE
  TWO_TO_THREE
  THREE_OR_MORE
  OPEN
}

model CustomerJourney {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @unique @db.ObjectId

  user Profile @relation(fields: [userId], references: [id])

  status JourneyStatus @default(NEW)

  assignedTo String?

  lastContactAt DateTime?

  createdAt DateTime @default(now())
}

enum JourneyStatus {
  NEW
  PROFILE_REVIEW
  MATCHING
  MATCH_SENT
  MEETING_SCHEDULED
  IN_DISCUSSION
  CLOSED
}

model Match {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  profileId        String      @db.ObjectId
  profile          Profile     @relation("ProfileMatches", fields: [profileId], references: [id], onDelete: Cascade)
  matchedProfileId String      @db.ObjectId
  matchedProfile   Profile     @relation("MatchedProfileMatches", fields: [matchedProfileId], references: [id], onDelete: Cascade)
  status           MatchStatus @default(PROPOSED)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  dates            DateRecord[]

  @@unique([profileId, matchedProfileId])
}

model DateRecord {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  matchId         String      @db.ObjectId
  match           Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  dateScheduledAt DateTime
  status          DateStatus  @default(SCHEDULED)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum MatchStatus {
  PROPOSED
  INTEREST_EXPRESSED
  ACCEPTED
  DECLINED
  ON_HOLD
  DISCONNECTED
}

enum DateStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
